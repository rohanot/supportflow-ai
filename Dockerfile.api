FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY pyproject.toml README.md ./
COPY app ./app
COPY prompts ./prompts
COPY evals ./evals
COPY sl_docs ./sl_docs

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir "fastapi>=0.115" "uvicorn[standard]>=0.30" "pydantic>=2.8" "pydantic-settings>=2.4" "sqlalchemy>=2.0" "alembic>=1.13" "psycopg[binary]>=3.2" "python-dotenv>=1.0" "httpx>=0.27" "tenacity>=8.5" "orjson>=3.10" "python-multipart>=0.0.9" "jinja2>=3.1" "pyyaml>=6.0" "pypdf>=5.0" "fastembed>=0.4" "onnxruntime>=1.18" "litellm>=1.44"

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
